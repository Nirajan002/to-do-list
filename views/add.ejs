<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add page</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('navbar') %>
    <h1>Add New Task</h1>
    <div class="container">
        <form action="/add" method="post">
            <input class="text" name="task" placeholder="Enter Your Task" required>
            <br><br>

            <textarea class="textarea" name="description" id="" placeholder="Enter Task Description" required></textarea>
            <br><br>
            <button type="submit">Add Task</button>
        </form>
    </div>
    
</body>
</html>